database:
  driver: "postgres"      # Database driver
  dbname: "task_manager"  # Database name
  username: "postgres"    # Database username
  password: "password"    # Database password
  host: "postgres"       # Host where the database is running
  port: "5432"            # Database port
  maxLifetime: 30         # Maximum connection lifetime (seconds)
  maxOpenConns: 100       # Maximum open connections
  maxIdleConns: 10        # Maximum idle connections

producer:
  enabled: false
  user: "guest"    
  password: "guest"   
  host: "rabbitmq"       
  port: "5672"           
  queueName: "celery"         
  exchange: "celery"
  connectionRetries: 3
  connectionRetryDelay: 5

tracing:
  enabled: true
  endpoint: "localhost:4318"  # Format: host:port (without http:// prefix)
  serviceName: "goreminder-api"
  insecure: true

metrics:
  enabled: true
  addr: ":9191"

server:
  port: 8080

ratelimit:
  enabled: true
  requests: 100        # Number of requests allowed
  window: "1m"          # Time window (e.g., "1m", "1h", "30s")

cors:
  enabled: true
  allowOrigins:         # List of allowed origins (use ["*"] for all)
    - "*"
  allowMethods:         # Allowed HTTP methods (optional, defaults to common methods)
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "OPTIONS"
    - "PATCH"
  allowHeaders:         # Allowed headers (optional, defaults to common headers)
    - "Content-Type"
    - "Authorization"
    - "X-Request-ID"
  exposeHeaders:        # Headers to expose to client (optional)
    - "X-Request-ID"
  allowCredentials: false  # Allow credentials in CORS requests
  maxAge: 3600          # Max age for preflight requests (in seconds)

autoreschedule:
  enabled: false        # Enable automatic rescheduling of tasks with startDate in the past
  time: "00:00"         # UTC time (HH:MM format) when autoreschedule should run (default: "00:00" if enabled)